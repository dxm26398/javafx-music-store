<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<GridPane xmlns:fx="http://javafx.com/fxml"
          fx:controller="Controller"
          hgap="10" vgap="8">
    <padding><Insets top="10" right="10" bottom="10" left="10"/></padding>

    <columnConstraints>
        <ColumnConstraints minWidth="120"/>
        <ColumnConstraints hgrow="ALWAYS"/>
    </columnConstraints>

    <Label text="Name" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
    <TextField fx:id="nameField" GridPane.columnIndex="1" GridPane.rowIndex="0" maxWidth="Infinity"/>

    <Label text="Street" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
    <TextField fx:id="streetField" GridPane.columnIndex="1" GridPane.rowIndex="1" maxWidth="Infinity"/>

    <Label text="City" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
    <TextField fx:id="cityField" GridPane.columnIndex="1" GridPane.rowIndex="2" maxWidth="Infinity"/>

    <Label text="State" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
    <TextField fx:id="stateField" GridPane.columnIndex="1" GridPane.rowIndex="3" maxWidth="Infinity"/>

    <Label text="Zip" GridPane.columnIndex="0" GridPane.rowIndex="4"/>
    <TextField fx:id="zipField" GridPane.columnIndex="1" GridPane.rowIndex="4" maxWidth="Infinity"/>

    <Label text="Choose One" GridPane.columnIndex="0" GridPane.rowIndex="5"/>
    <HBox spacing="150" GridPane.columnIndex="1" GridPane.rowIndex="5">
        <CheckBox fx:id="appCheck" text="APP" onAction="#handleAppCheck"/>
        <CheckBox fx:id="musicCheck" text="MUSIC" onAction="#handleMusicCheck"/>
    </HBox>

    <Label fx:id="musicTypeLabel" text="Type of Music" GridPane.columnIndex="0" GridPane.rowIndex="6"/>
    <ComboBox fx:id="musicCombo" maxWidth="Infinity" visibleRowCount="3"
              GridPane.columnIndex="1" GridPane.rowIndex="6"/>

    <Label fx:id="appTypeLabel" text="Type of App" GridPane.columnIndex="0" GridPane.rowIndex="7"/>
    <HBox spacing="40" GridPane.columnIndex="1" GridPane.rowIndex="7">
        <RadioButton fx:id="gameRadio" text="GAME"/>
        <RadioButton fx:id="productivityRadio" text="PRODUCTIVITY"/>
        <RadioButton fx:id="educationRadio" text="EDUCATION"/>
    </HBox>

    <Label text="Enter Title" GridPane.columnIndex="0" GridPane.rowIndex="8"/>
    <TextField fx:id="titleField" GridPane.columnIndex="1" GridPane.rowIndex="8" maxWidth="Infinity"/>

    <Label text="Date Purchased" GridPane.columnIndex="0" GridPane.rowIndex="9"/>
    <TextField fx:id="dateField" GridPane.columnIndex="1" GridPane.rowIndex="9" maxWidth="Infinity"/>

    <Label text="Account Number" GridPane.columnIndex="0" GridPane.rowIndex="10"/>
    <TextField fx:id="accountField" GridPane.columnIndex="1" GridPane.rowIndex="10" maxWidth="Infinity"/>

    <HBox spacing="10" GridPane.columnIndex="0" GridPane.rowIndex="11" GridPane.columnSpan="2">
        <Button fx:id="submitButton" text="SUBMIT" onAction="#handleSubmit" maxWidth="Infinity" HBox.hgrow="ALWAYS"/>
        <Button fx:id="finishButton" text="FINISH" onAction="#handleFinish" maxWidth="Infinity" HBox.hgrow="ALWAYS"/>
    </HBox>

</GridPane>